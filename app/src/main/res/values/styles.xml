<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SnackBarStyle" parent="Widget.Material3.Snackbar">
        <item name="android:backgroundTint">?attr/colorSecondaryContainer</item>
    </style>

    <style name="SnackBarStyle.TextView" parent="Widget.Material3.Snackbar.TextView">
        <item name="android:textColor">?attr/colorOnSecondaryContainer</item>
    </style>

    <style name="SnackBarStyle.Button" parent="Widget.Material3.Button.TextButton.Snackbar">
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="Base.Theme.ColorBlendr.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_round</item>
        <item name="postSplashScreenTheme">@style/Base.Theme</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/ic_branding_image</item>
    </style>

    <style name="AppMaterialAlertDialog" parent="ThemeOverlay.Material3Expressive.MaterialAlertDialog">
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/DialogNegativeButton</item>
    </style>

    <style name="DialogPositiveButton" parent="Widget.Material3Expressive.Button">
        <item name="android:minWidth">@dimen/m3_btn_dialog_btn_min_width</item>
        <item name="android:layout_marginStart">@dimen/m3_btn_dialog_btn_spacing</item>
        <item name="android:layout_marginLeft">@dimen/m3_btn_dialog_btn_spacing</item>
    </style>

    <style name="DialogNegativeButton" parent="Widget.Material3Expressive.Button.OutlinedButton">
        <item name="android:minWidth">@dimen/m3_btn_dialog_btn_min_width</item>
        <item name="android:layout_marginStart">@dimen/m3_btn_dialog_btn_spacing</item>
        <item name="android:layout_marginLeft">@dimen/m3_btn_dialog_btn_spacing</item>
    </style>

</resources>